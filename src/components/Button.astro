---
/**
 * Retro-arcade "menu select" button. Renders an `<a>` when `href` is given,
 * otherwise a `<button>`. Hover "lifts" like a highlighted menu item, active
 * "presses" it down — plain CSS transforms tied to the same
 * `prefers-reduced-motion` media query as the rest of the site (global.css),
 * so it degrades the instant the OS preference is set, without needing a
 * client-side island just to swap a transform (PRD §9 micro-interactions).
 */
export interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  type?: 'button' | 'submit';
  /** Forwarded when `href` is set, e.g. for external links */
  target?: string;
  rel?: string;
}

const { href, variant = 'primary', type = 'button', target, rel } = Astro.props;

const className = `button button--${variant}`;
---

{
  href ? (
    <a class={className} href={href} target={target} rel={rel}>
      <slot />
    </a>
  ) : (
    <button class={className} type={type}>
      <slot />
    </button>
  )
}

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border: var(--border-width) solid currentColor;
    border-radius: var(--radius-md);
    background-color: transparent;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    text-decoration: none;
    line-height: 1;
    cursor: pointer;
    transition:
      color 0.15s ease-out,
      background-color 0.15s ease-out,
      box-shadow 0.15s ease-out,
      transform 0.12s ease-out;
  }

  .button:hover {
    transform: translateY(-0.125rem);
  }

  .button:active {
    transform: translateY(0.0625rem) scale(0.97);
    transition-duration: 0.05s;
  }

  .button--primary {
    color: var(--color-bg);
    background-color: var(--color-green);
    border-color: var(--color-green);
    box-shadow: var(--glow-green);
  }

  .button--primary:hover {
    box-shadow:
      var(--glow-green),
      0 4px 16px rgb(57 255 20 / 35%);
    filter: brightness(1.1);
  }

  .button--secondary {
    color: var(--color-amber);
  }

  .button--secondary:hover {
    background-color: var(--color-amber);
    color: var(--color-bg);
    box-shadow: var(--glow-amber);
  }

  .button--ghost {
    color: var(--color-fg);
    border-color: var(--color-border);
  }

  .button--ghost:hover {
    color: var(--color-green);
    border-color: currentColor;
  }
</style>
