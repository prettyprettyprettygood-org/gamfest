---
import Section from '../components/Section.astro';
import Reveal from '../components/motion/Reveal';
---

<Section id="recap" eyebrow="Level 01 // Recap" title="How it went">
  <Reveal client:visible>
    <p class="lede">
      Somebody gave the nerds a video cable hooked up to a giant LED billboard.
      This was going to get nuts — and it did, in the best way.
    </p>
    <p>
      GAM[fest] #1 took over a corner of Baltimore's Charles Street Promenade
      with free-play on a five-story screen, live music following along to a
      Zelda 1 speedrun, tabletop demos, live art on the board, and an hourly
      stream of nerd trivia. Folks wandered in from the bigger festival next
      door, grabbed a controller, and got a turn on the biggest screen they'll
      probably ever play on. <a href="#gallery">See the gallery</a> for the highlights,
      or <a href="#lineup">check the lineup</a> for who made it happen.
    </p>
  </Reveal>
</Section>
