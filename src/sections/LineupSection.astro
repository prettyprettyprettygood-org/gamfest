---
import { Image } from 'astro:assets';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';
import Reveal from '../components/motion/Reveal';
import VideoPlayer from '../components/islands/VideoPlayer';

import gamfestLivePlayVideo from '../assets/video/gamfest-live-play.mp4';
import quickSavePhoto from '../assets/images/quicksave.png';
import quickSaveBandPhoto from '../assets/images/quicksave-band.png';
import marsMagmaPhoto from '../assets/images/mars-magma.png';
import dkAdventuresPhoto from '../assets/images/dk-adventures.jpg';
import christianDaltonPhoto from '../assets/images/christian-dalton-dj.png';
import christianDaltonPhoto2 from '../assets/images/christian-dalton-dj-1.png';

const featuredActs = [
  {
    name: 'Quick Save!',
    role: 'live in front of the billboard',
    image: {
      src: quickSavePhoto,
      alt: 'Stylized cartoon-avatar lineup graphic for Quick Save, showing the six band members as character portraits against a dark background.',
    },
    secondaryImage: {
      src: quickSaveBandPhoto,
      alt: 'Quick Save performing live outdoors, members playing guitar and singing on a stage against a city skyline backdrop.',
    },
    bio: 'Taking a break from the studio to play their first summer show, Quick Save brought their jazz/rock/meme fusion to the GAM[fest] stage. They played favorites and new tunes from their upcoming studio debut.',
    socials: [
      {
        name: 'instagram' as const,
        href: 'https://www.instagram.com/quicksavebaltimore/',
        label: 'Quick Save on Instagram',
      },
      {
        name: 'facebook' as const,
        href: 'http://facebook.com/quicksaveband/',
        label: 'Quick Save on Facebook',
      },
      {
        name: 'youtube' as const,
        href: 'https://www.youtube.com/QuickSaveBand',
        label: 'Quick Save on YouTube',
      },
      {
        name: 'bandcamp' as const,
        href: 'https://quicksave.bandcamp.com/',
        label: 'Quick Save on Bandcamp',
      },
    ],
  },
  {
    name: 'DJ Christian Dalton',
    role: 'Linking the sets together',
    image: {
      src: christianDaltonPhoto,
      alt: 'Christian Dalton DJing at a table with a laptop in front of a screen showing retro game graphics.',
    },
    secondaryImage: {
      src: christianDaltonPhoto2,
      alt: 'Christian Dalton at the DJ booth from a wider angle, with a lit-up stage setup behind him.',
    },
    bio: "A Maryland-native DJ/producer bringing dance music and excellent vibes — a particular fan of funky basslines, driving grooves, and entrancing leads. His goal is simple: take you on a journey you didn't know you needed to hear.",
    socials: [
      {
        name: 'instagram' as const,
        href: 'https://www.instagram.com/christiandalton.music/',
        label: 'Christian Dalton on Instagram',
      },
      {
        name: 'link' as const,
        href: 'https://linktr.ee/Christian.Dalton',
        label: 'Christian Dalton on Linktree',
      },
    ],
  },
  {
    name: 'Mars Magma × DK Adventures',
    role: 'Live Zelda speedrun',
    image: {
      src: marsMagmaPhoto,
      alt: 'Mars Magma performing live in a bright orange wig and headlamp behind a bank of game consoles and a monitor, with the "Hipscore: The Happy Hour for Gamers" logo overlaid.',
    },
    secondaryImage: {
      src: dkAdventuresPhoto,
      alt: 'Dom and Kevin of DK Adventures performing on an outdoor wooden stage surrounded by trees — one on drums, one on keyboard and vocals — with a "DK Adventures" text overlay.',
    },
    bio: 'A full Legend of Zelda speedrun on the billboard, scored in real time: Mars Magma ran the game while Dom and Kevin of DK Adventures improvised a live soundtrack to every room and rupee.',
    socials: [
      {
        name: 'instagram' as const,
        href: 'https://www.instagram.com/marsapalooza_arcade/',
        label: 'Mars Magma on Instagram',
      },
      {
        name: 'facebook' as const,
        href: 'https://www.facebook.com/DKAdventuresBand/',
        label: 'DK Adventures on Facebook',
      },
    ],
  },
];

const lineupExtras = [
  {
    title: 'Freeplay, unlocked',
    body: 'Anyone could grab a controller — on the consoles set up streetside, or on the billboard itself.',
  },
  {
    title: 'Tabletop crews ran live demos',
    body: 'Card and tabletop folks set up shop and showed off their games to passersby all afternoon.',
  },
  {
    title: 'Live art, drawn right on the board',
    body: 'Local artists turned the five-story screen into a canvas between sets.',
  },
  {
    title: 'Nerd trivia, every hour on the hour',
    body: 'A fresh round (and a fresh stack of prizes) every hour, all day long.',
  },
];
---

<Section id="lineup" eyebrow="Level 02 // Lineup" title="Achievements unlocked">
  <Reveal client:visible>
    <p class="lede">
      A run-down of who and what made the day — headliners first, then
      everything else that was happening on (and around) the big screen.
    </p>
  </Reveal>
  <Reveal client:visible delay={0.12}>
    <ul class="acts">
      {
        featuredActs.map((act) => (
          <li>
            <Card>
              <div class="act-card__media">
                <Image
                  src={act.image.src}
                  alt={act.image.alt}
                  class="act-card__image"
                  width={480}
                />
                {act.secondaryImage && (
                  <Image
                    src={act.secondaryImage.src}
                    alt={act.secondaryImage.alt}
                    class="act-card__image act-card__image--secondary"
                    width={320}
                  />
                )}
              </div>
              <div class="act-card__body">
                <p class="act-card__role">{act.role}</p>
                <h3 class="act-card__name">{act.name}</h3>
                <p class="act-card__bio">{act.bio}</p>
                <ul class="act-card__socials">
                  {act.socials.map((social) => (
                    <li>
                      <a
                        class="icon-link"
                        href={social.href}
                        target="_blank"
                        rel="noreferrer"
                      >
                        <Icon name={social.name} label={social.label} />
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </Card>
          </li>
        ))
      }
    </ul>
  </Reveal>
  <div class="lineup-extras-wrap">
    <div class="lineup-extras-col">
      <Reveal client:visible delay={0.18}>
        <h3 class="lineup-extras__heading">Also unlocked that day</h3>
      </Reveal>
      <ul class="lineup-extras" data-stagger>
        {
          lineupExtras.map((entry, index) => (
            <li class="lineup-extras__item" style={`--stagger-i: ${index}`}>
              <span class="lineup-extras__index" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </span>
              <div>
                <h4 class="lineup-extras__title">{entry.title}</h4>
                <p>{entry.body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
    <Reveal client:visible delay={0.28} className="lineup-extras-video-col">
      <VideoPlayer client:visible src={gamfestLivePlayVideo} />
    </Reveal>
  </div>
</Section>

<script>
  // Stagger the "Also unlocked" list items into view on desktop scroll.
  const staggerLists = document.querySelectorAll<HTMLElement>('[data-stagger]');
  const staggerMotion = window.matchMedia('(min-width: 48rem)');
  if (staggerLists.length && staggerMotion.matches) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('lineup-extras--visible');
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    staggerLists.forEach((el) => obs.observe(el));
  }

  // Sync video column height to the left column so they match
  const leftCol = document.querySelector<HTMLElement>('.lineup-extras-col');
  const videoCol = document.querySelector<HTMLElement>(
    '.lineup-extras-video-col',
  );
  if (leftCol && videoCol) {
    const wide = window.matchMedia('(min-width: 48rem)');
    const sync = () => {
      if (wide.matches) {
        videoCol.style.height = `${leftCol.offsetHeight}px`;
      } else {
        videoCol.style.height = '';
      }
    };
    sync();
    new ResizeObserver(sync).observe(leftCol);
    wide.addEventListener('change', sync);
  }
</script>

<style>
  /* -------------------------------------------------------------------
   * Headliner "act" cards — image + bio + icon socials
   * ----------------------------------------------------------------- */
  .acts {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    list-style: none;
    margin-bottom: var(--space-7);
  }

  .acts > li {
    display: flex;
  }

  .acts > li > :global(.card) {
    width: 100%;
    padding: 0;
    overflow: hidden;
    box-shadow: var(--glow-green-soft);
    border-color: var(--color-green);
    transition:
      transform 0.2s ease-out,
      box-shadow 0.2s ease-out;
  }

  .acts > li:hover > :global(.card) {
    transform: translateY(-6px);
    box-shadow:
      0 0 1.5rem rgb(var(--color-green-rgb) / 55%),
      0 12px 32px rgb(0 0 0 / 40%);
  }

  .acts > li > :global(.card) > :global(.card__body) {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-4);
    padding: var(--space-5);
  }

  .act-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-3);
  }

  .act-card__media {
    position: relative;
    display: flex;
    background-color: var(--color-bg);
  }

  .act-card__image {
    width: 100%;
    height: 12rem;
    object-fit: cover;
  }

  .act-card__image--secondary {
    width: 40%;
    flex-shrink: 0;
    border-inline-start: var(--border-width) solid var(--color-border);
  }

  .act-card__role {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-green);
  }

  .act-card__name {
    margin: 0;
  }

  .act-card__bio {
    flex: 1;
  }

  .act-card__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding-top: var(--space-3);
  }

  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 2.5rem;
    block-size: 2.5rem;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition:
      color 0.15s ease-out,
      border-color 0.15s ease-out,
      transform 0.12s ease-out;
  }

  .icon-link:hover {
    color: var(--color-green);
    border-color: currentColor;
    transform: translateY(-0.125rem);
  }

  /* -------------------------------------------------------------------
   * "Also unlocked" extras list — deliberately not cards so four items
   * don't strand a lone card in the 3-up grid
   * ----------------------------------------------------------------- */
  .lineup-extras-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .lineup-extras-col {
    min-width: 0;
  }

  :global(.lineup-extras-video-col) {
    min-width: 0;
  }

  :global(.lineup-extras-video-col .video-player) {
    max-height: 14rem;
  }

  :global(.lineup-extras-video-col .video-player__video) {
    max-height: 14rem;
    object-fit: cover;
  }

  .lineup-extras__heading {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-4);
  }

  .lineup-extras {
    display: flex;
    flex-direction: column;
    list-style: none;
  }

  .lineup-extras__item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-4);
    padding-left: var(--space-3);
    border-bottom: var(--border-width) solid var(--color-border);
    border-left: var(--border-width) solid transparent;
    opacity: 0;
    transform: translateX(-10px);
    transition:
      opacity 0.34s ease-out calc(var(--stagger-i, 0) * 0.06s),
      transform 0.34s ease-out calc(var(--stagger-i, 0) * 0.06s),
      border-left-color 0.2s ease-out 0s,
      background-color 0.2s ease-out 0s;
  }

  .lineup-extras__item:first-child {
    border-top: var(--border-width) solid var(--color-border);
  }

  .lineup-extras__item:hover {
    border-left-color: var(--color-green);
    background-color: rgb(var(--color-green-rgb) / 0.03);
  }

  .lineup-extras--visible .lineup-extras__item {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 47.999rem) {
    .lineup-extras__item {
      opacity: 1;
      transform: none;
      transition:
        border-left-color 0.2s ease-out,
        background-color 0.2s ease-out;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lineup-extras__item {
      opacity: 1;
      transform: none;
      transition:
        border-left-color 0.2s ease-out,
        background-color 0.2s ease-out;
    }
  }

  .lineup-extras__index {
    font-family: var(--font-pixel);
    font-size: var(--text-xs);
    color: var(--color-green);
    flex-shrink: 0;
    text-shadow: 0 0 0.5rem rgb(var(--color-green-rgb) / 60%);
  }

  .lineup-extras__title {
    margin: 0 0 var(--space-1);
    font-size: var(--text-md);
  }

  /* Desktop breakpoints */
  @media (min-width: 48rem) {
    .acts {
      grid-template-columns: repeat(2, 1fr);
    }

    .lineup-extras-wrap {
      grid-template-columns: 1.8fr 0.8fr;
      align-items: start;
    }

    :global(.lineup-extras-video-col .video-player) {
      height: 100%;
      max-height: none;
    }

    :global(.lineup-extras-video-col .video-player__video) {
      height: 100%;
      max-height: none;
      object-fit: cover;
    }
  }

  @media (min-width: 64rem) {
    .acts {
      grid-template-columns: repeat(3, 1fr);
    }

    .act-card__media {
      flex-direction: column;
    }

    .act-card__image--secondary {
      width: 100%;
      height: 8rem;
      border-inline-start: none;
      border-block-start: var(--border-width) solid var(--color-border);
    }
  }
</style>
