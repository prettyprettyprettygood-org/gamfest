---
import Section from '../components/Section.astro';
import Reveal from '../components/motion/Reveal';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import CopyButton from '../components/islands/CopyButton';
import {
  discordUrl,
  facebookUrl,
  contactEmail,
  formspreeUrl,
  turnstileSiteKey,
} from '../data/config';
---

<Section id="contact" eyebrow="Continue?" title="Follow for the announcement">
  <Reveal client:visible>
    <p class="lede">
      GAM[fest] #2 is TBD — but we'll shout about it the moment it's locked in.
      Insert coin (or just hit follow) so you hear it first:
    </p>
  </Reveal>
  <div class="contact-layout">
    <Reveal client:visible delay={0.12} className="contact-layout__form">
      <div class="contact-form-wrapper">
        <form
          class="contact-form"
          id="contact-form"
          action={formspreeUrl}
          method="POST"
        >
          <header class="contact-form__header">
            <h3 class="contact-form__title">Get in touch</h3>
            <p class="contact-form__subtitle">
              Got an idea, a question, or want to pitch an activity for next
              time?
            </p>
          </header>
          <input type="hidden" name="_subject" value="GAM[fest] contact form" />
          <div class="contact-form__row">
            <label for="contact-name">Name</label>
            <input
              id="contact-name"
              name="name"
              type="text"
              autocomplete="name"
              required
            />
          </div>
          <div class="contact-form__row">
            <label for="contact-email">Email</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              autocomplete="email"
              required
            />
          </div>
          <div class="contact-form__row">
            <label for="contact-message">Message</label>
            <textarea id="contact-message" name="message" rows="4" required
            ></textarea>
          </div>
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-size="flexible"
          >
          </div>
          <p
            class="contact-form__error"
            id="contact-form-error"
            role="alert"
            hidden
          >
          </p>
          <Button type="submit" variant="primary">Send it</Button>
          <p class="contact-form__privacy-note">
            This form is handled by <a
              href="https://formspree.io/legal/privacy-policy/"
              target="_blank"
              rel="noreferrer">Formspree</a
            > and checked for spam by Cloudflare Turnstile — we only see what
            you type above, used to reply to you. No tracking, no mailing
            list, no other data collected.
          </p>
        </form>
        <div
          class="contact-form__success"
          id="contact-form-success"
          role="status"
          aria-live="polite"
          hidden
        >
          <p class="contact-form__success-title">Thanks — we'll be in touch!</p>
        </div>
      </div>
    </Reveal>
    <Reveal client:visible delay={0.18} className="contact-layout__follow">
      <div class="follow-card">
        <a
          class="follow-item"
          href={discordUrl}
          target="_blank"
          rel="noreferrer"
        >
          <Icon name="discord" label="Discord" />
          <div class="follow-item__text">
            <p class="follow-item__label">Discord</p>
            <p class="follow-item__sub">Join the server</p>
          </div>
        </a>
        <a
          class="follow-item"
          href={facebookUrl}
          target="_blank"
          rel="noreferrer"
        >
          <Icon name="facebook" label="Facebook" />
          <div class="follow-item__text">
            <p class="follow-item__label">Facebook</p>
            <p class="follow-item__sub">Follow the page</p>
          </div>
        </a>
        <div class="follow-item follow-item--email">
          <Icon name="mail" label="Email" />
          <div class="follow-item__text">
            <a class="follow-item__label" href={`mailto:${contactEmail}`}
              >Email</a
            >
            <p class="follow-item__sub">{contactEmail}</p>
          </div>
          <CopyButton client:visible value={contactEmail} label="Copy" />
        </div>
      </div>
    </Reveal>
  </div>
</Section>

<script
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer
  is:inline></script>

<style>
  .contact-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-layout__form,
  .contact-layout__follow {
    min-width: 0;
  }

  .follow-card {
    display: flex;
    flex-direction: column;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-bg-raised);
  }

  .follow-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    text-decoration: none;
    color: var(--color-fg);
    border-bottom: var(--border-width) solid var(--color-border);
    transition: background-color 0.15s ease-out;
  }

  .follow-item:last-child {
    border-bottom: none;
  }

  a.follow-item:hover {
    background-color: var(--color-bg);
  }

  a.follow-item:hover .follow-item__label {
    color: var(--color-green);
  }

  a.follow-item:hover :global(.icon) {
    color: var(--color-green);
  }

  .follow-item :global(.icon) {
    flex-shrink: 0;
    inline-size: 1.75rem;
    block-size: 1.75rem;
    color: var(--color-green);
    transition: color 0.15s ease-out;
  }

  .follow-item__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .follow-item__label {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-fg);
    transition: color 0.15s ease-out;
  }

  a.follow-item__label {
    text-decoration: none;
  }

  .follow-item__label:hover {
    color: var(--color-green);
  }

  .follow-item__sub {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  .follow-item--email :global(.copy-button) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    margin-inline-start: auto;
    padding: var(--space-2) var(--space-3);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: transparent;
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    cursor: pointer;
    transition:
      color 0.15s ease-out,
      border-color 0.15s ease-out,
      background-color 0.15s ease-out;
  }

  .follow-item--email :global(.copy-button:hover) {
    color: var(--color-green);
    border-color: var(--color-green);
    background-color: rgb(var(--color-green-rgb) / 0.05);
  }

  .follow-item--email :global(.copy-button .icon) {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .contact-form[hidden] {
    display: none;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    background-color: var(--color-bg-raised);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .contact-form__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-form__title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .contact-form__subtitle {
    margin: 0;
    color: var(--color-fg-muted);
  }

  .contact-form__row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-form__row label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-green-text);
  }

  .contact-form__row input,
  .contact-form__row textarea {
    padding: var(--space-3);
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-fg);
    font-family: var(--font-body);
    font-size: var(--text-base);
    resize: vertical;
  }

  .contact-form__row input:focus-visible,
  .contact-form__row textarea:focus-visible {
    outline: var(--border-width) solid var(--color-focus-ring);
    outline-offset: 0.1em;
    border-color: var(--color-focus-ring);
  }

  .contact-form__error {
    margin: 0;
    color: var(--color-amber);
    font-size: var(--text-sm);
  }

  .contact-form__privacy-note {
    margin: 0;
    color: var(--color-fg-muted);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
  }

  .contact-form__success[hidden] {
    display: none;
  }

  .contact-form__success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-5);
    background-color: var(--color-bg-raised);
    border: var(--border-width) solid var(--color-green);
    border-radius: var(--radius-lg);
    box-shadow: var(--glow-green-soft);
    text-align: center;
  }

  .contact-form__success-title {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-green-text);
  }

  /* Desktop: form takes the wider left column, follow card stacks at right */
  @media (min-width: 48rem) {
    .contact-layout {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-6);
      align-items: start;
    }
  }
</style>

<script>
  // Submit the contact form via fetch instead of a full-page POST, so a
  // successful send swaps in an inline "thanks" message instead of
  // redirecting to Formspree's hosted confirmation page.
  interface FormspreeErrorBody {
    errors?: { message?: string }[];
  }

  declare global {
    interface Window {
      // Loaded async from the Cloudflare Turnstile <script> above — may not
      // exist yet if the widget hasn't finished loading.
      turnstile?: { reset: (container?: string | Element) => void };
    }
  }

  const form = document.querySelector<HTMLFormElement>('#contact-form');
  const success = document.querySelector<HTMLElement>('#contact-form-success');
  const error = document.querySelector<HTMLElement>('#contact-form-error');
  const turnstileWidget = form?.querySelector<HTMLElement>('.cf-turnstile');

  const defaultErrorMessage =
    'Something went wrong sending that — please try again, or email us directly.';

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const submitButton = form.querySelector<HTMLButtonElement>(
      'button[type="submit"]',
    );
    if (error) {
      error.hidden = true;
      error.textContent = '';
    }
    if (submitButton) submitButton.disabled = true;

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (!response.ok) {
        const body: FormspreeErrorBody = await response
          .json()
          .catch(() => ({}));
        throw new Error(body.errors?.[0]?.message || defaultErrorMessage);
      }

      form.hidden = true;
      success?.removeAttribute('hidden');
    } catch (err) {
      if (error) {
        error.hidden = false;
        error.textContent =
          err instanceof Error && err.message
            ? err.message
            : defaultErrorMessage;
      }
      // The Turnstile token is single-use — reset the widget so a retry
      // can get a fresh one instead of failing again silently.
      if (turnstileWidget) window.turnstile?.reset(turnstileWidget);
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
  });

  // A bfcache restore (e.g. backgrounding/returning to the tab on mobile, or
  // the browser back button) brings the DOM back exactly as it was left,
  // including the "thanks" state — reset it so a restored page shows the
  // form again rather than a stale success message.
  window.addEventListener('pageshow', (event) => {
    if (!event.persisted || !form) return;

    form.reset();
    form.hidden = false;
    success?.setAttribute('hidden', '');
    if (error) {
      error.hidden = true;
      error.textContent = '';
    }
    if (turnstileWidget) window.turnstile?.reset(turnstileWidget);
  });
</script>
