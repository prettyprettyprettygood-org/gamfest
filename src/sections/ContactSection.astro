---
import Section from '../components/Section.astro';
import Reveal from '../components/motion/Reveal';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import {
  discordUrl,
  facebookUrl,
  contactEmail,
  formspreeUrl,
} from '../data/config';
---

<Section id="contact" eyebrow="Continue?" title="Follow for the announcement">
  <Reveal client:visible>
    <p class="lede">
      GAM[fest] #2 is TBD — but we'll shout about it the moment it's locked in.
      Insert coin (or just hit follow) so you hear it first:
    </p>
  </Reveal>
  <Reveal client:visible delay={0.12}>
    <div class="follow-card">
      <a class="follow-item" href={discordUrl} target="_blank" rel="noreferrer">
        <Icon name="discord" label="Discord" />
        <div class="follow-item__text">
          <p class="follow-item__label">Discord</p>
          <p class="follow-item__sub">Join the server</p>
        </div>
      </a>
      <a
        class="follow-item"
        href={facebookUrl}
        target="_blank"
        rel="noreferrer"
      >
        <Icon name="facebook" label="Facebook" />
        <div class="follow-item__text">
          <p class="follow-item__label">Facebook</p>
          <p class="follow-item__sub">Follow the page</p>
        </div>
      </a>
      <a class="follow-item" href={`mailto:${contactEmail}`}>
        <Icon name="mail" label="Email" />
        <div class="follow-item__text">
          <p class="follow-item__label">{contactEmail}</p>
          <p class="follow-item__sub">Send us a message</p>
        </div>
      </a>
    </div>
  </Reveal>
  <Reveal client:visible delay={0.18}>
    <form class="contact-form" action={formspreeUrl} method="POST">
      <h3 class="contact-form__heading">
        Got an idea, a question, or want to pitch an activity for next time?
      </h3>
      <input type="hidden" name="_subject" value="GAM[fest] contact form" />
      <div class="contact-form__row">
        <label for="contact-name">Name</label>
        <input
          id="contact-name"
          name="name"
          type="text"
          autocomplete="name"
          required
        />
      </div>
      <div class="contact-form__row">
        <label for="contact-email">Email</label>
        <input
          id="contact-email"
          name="email"
          type="email"
          autocomplete="email"
          required
        />
      </div>
      <div class="contact-form__row">
        <label for="contact-message">Message</label>
        <textarea id="contact-message" name="message" rows="4" required
        ></textarea>
      </div>
      <Button type="submit" variant="primary">Send it</Button>
    </form>
  </Reveal>
</Section>

<style>
  .follow-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-top: var(--space-6);
    margin-bottom: var(--space-7);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-bg-raised);
  }

  .follow-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    text-decoration: none;
    color: var(--color-fg);
    border-bottom: var(--border-width) solid var(--color-border);
    transition: background-color 0.15s ease-out;
  }

  .follow-item:last-child {
    border-bottom: none;
  }

  a.follow-item:hover {
    background-color: var(--color-bg);
  }

  a.follow-item:hover .follow-item__label {
    color: var(--color-green);
  }

  a.follow-item:hover :global(.icon) {
    color: var(--color-green);
  }

  .follow-item :global(.icon) {
    flex-shrink: 0;
    inline-size: 1.75rem;
    block-size: 1.75rem;
    color: var(--color-green);
    transition: color 0.15s ease-out;
  }

  .follow-item__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .follow-item__label {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-fg);
    transition: color 0.15s ease-out;
  }

  .follow-item__sub {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    background-color: var(--color-bg-raised);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .contact-form__heading {
    margin: 0;
    font-size: var(--text-lg);
  }

  .contact-form__row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-form__row label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-green-text);
  }

  .contact-form__row input,
  .contact-form__row textarea {
    padding: var(--space-3);
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-fg);
    font-family: var(--font-body);
    font-size: var(--text-base);
    resize: vertical;
  }

  .contact-form__row input:focus-visible,
  .contact-form__row textarea:focus-visible {
    outline: var(--border-width) solid var(--color-focus-ring);
    outline-offset: 0.1em;
    border-color: var(--color-focus-ring);
  }

  /* Desktop: follow card switches to a horizontal three-column layout */
  @media (min-width: 48rem) {
    .follow-card {
      flex-direction: row;
    }

    .follow-item {
      flex: 1;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      border-bottom: none;
      border-right: var(--border-width) solid var(--color-border);
    }

    .follow-item:last-child {
      border-right: none;
    }

    .follow-item__text {
      align-items: center;
    }
  }
</style>
