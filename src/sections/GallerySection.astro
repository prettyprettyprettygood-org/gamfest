---
import { getImage } from 'astro:assets';
import Section from '../components/Section.astro';
import Reveal from '../components/motion/Reveal';
import GalleryModal from '../components/islands/GalleryModal';

import billboardPhoto from '../assets/images/gamfest-billboard.jpg';
import bigScreenPhoto from '../assets/images/game-on-big-screen.webp';
import yoshiBillboardPhoto from '../assets/images/yoshi-billboard.webp';
import gamFestSignPhoto from '../assets/images/gam-fest-sign.jpg';
import marsLivePhoto from '../assets/images/mars-live.jpg';
import marsRunPhoto from '../assets/images/mars-run.jpg';
import gamfestBillboardLargePhoto from '../assets/images/gamfest-billboard-large.png';
import gamfestBillboardLivePhoto from '../assets/images/gamfest-billboard-live.png';
import gamfestBillboardSkyPhoto from '../assets/images/gamfest-billboard-sky.png';
import gamfestBillboardSkylinePhoto from '../assets/images/gamfest-billboard-skyline.png';
import gamfestBillboardStreetPhoto from '../assets/images/gamfest-billboard-street.png';
import gamfestPerformancePhoto from '../assets/images/gamfest-performance.jpg';

const galleryItems = [
  {
    thumbSrc: (
      await getImage({ src: gamFestSignPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: gamFestSignPhoto, width: 1400 })).src,
    alt: 'A GAM[fest] festival sign on display at the event.',
    caption: 'The GAM[fest] sign welcoming attendees.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({
        src: gamfestBillboardSkylinePhoto,
        width: 600,
        format: 'webp',
      })
    ).src,
    fullSrc: (
      await getImage({
        src: gamfestBillboardSkylinePhoto,
        width: 1400,
        format: 'webp',
      })
    ).src,
    alt: 'The GAM[fest] billboard showing a Super Mario World underwater level beside the Baltimore skyline and the street festival below.',
    caption: 'Super Mario World skyline-sized.',
    thumbPosition: 'left center',
  },
  {
    thumbSrc: (
      await getImage({ src: billboardPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: billboardPhoto, width: 1400 })).src,
    alt: 'A five-story LED billboard displaying the Legend of Zelda 1986 title screen — sword, shield emblem, and "Push Start Button" — with the GAM[fest] "Games | Art | Music | Fest" banner and the date and web address overlaid above and below, against a clear blue sky.',
    caption: 'The billboard: The Legend of Zelda, five stories tall.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({ src: bigScreenPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: bigScreenPhoto, width: 1200 })).src,
    alt: 'A crowd gathers on a Baltimore street corner, watching Super Mario Bros. run on a giant LED billboard mounted above a brick warehouse, with traffic cones and an inflatable arch set up for the festival on the street below.',
    caption: 'The crowd gathers as Mario takes the big screen.',
    thumbPosition: 'top',
  },
  {
    thumbSrc: (
      await getImage({ src: yoshiBillboardPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: yoshiBillboardPhoto, width: 1200 })).src,
    alt: 'A tall view of the LED billboard mounted above a Station North brick warehouse, displaying Super Mario World gameplay, with festival tents and a small crowd gathered on the street below.',
    caption:
      'Super Mario World, five stories up - and a street-level view of the whole setup.',
    thumbPosition: 'top center',
  },
  {
    thumbSrc: (
      await getImage({ src: marsLivePhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: marsLivePhoto, width: 1400 })).src,
    alt: 'Mars performing live on stage at GAM[fest].',
    caption: 'Mars live on stage.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({ src: marsRunPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: marsRunPhoto, width: 1400 })).src,
    alt: 'Mars running during a performance at GAM[fest].',
    caption: 'Mars bringing the energy.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({
        src: gamfestBillboardLivePhoto,
        width: 600,
        format: 'webp',
      })
    ).src,
    fullSrc: (
      await getImage({
        src: gamfestBillboardLivePhoto,
        width: 1400,
        format: 'webp',
      })
    ).src,
    alt: 'A rooftop view of the GAM[fest] billboard showing a live Zelda speedrun feed and timer above Station North.',
    caption: 'The Zelda run, live over Station North.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({
        src: gamfestBillboardSkyPhoto,
        width: 600,
        format: 'webp',
      })
    ).src,
    fullSrc: (
      await getImage({
        src: gamfestBillboardSkyPhoto,
        width: 1400,
        format: 'webp',
      })
    ).src,
    alt: 'The GAM[fest] billboard playing Super Mario World against a bright blue Baltimore sky.',
    caption: 'Super Mario World and a whole lot of blue sky.',
    thumbPosition: 'right center',
  },
  {
    thumbSrc: (
      await getImage({
        src: gamfestBillboardStreetPhoto,
        width: 600,
        format: 'webp',
      })
    ).src,
    fullSrc: (
      await getImage({
        src: gamfestBillboardStreetPhoto,
        width: 1400,
        format: 'webp',
      })
    ).src,
    alt: 'The GAM[fest] billboard playing Super Mario Bros. above Charles Street, with festival tents and attendees below.',
    caption: 'The festival stretched from street level to skyline.',
    thumbPosition: 'left center',
  },
  {
    thumbSrc: (
      await getImage({
        src: gamfestBillboardLargePhoto,
        width: 600,
        format: 'webp',
      })
    ).src,
    fullSrc: (
      await getImage({
        src: gamfestBillboardLargePhoto,
        width: 1400,
        format: 'webp',
      })
    ).src,
    alt: 'A close low-angle view of the GAM[fest] billboard showing a Legend of Zelda dungeon room.',
    caption: 'Dungeon crawling, five stories tall.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({
        src: gamfestPerformancePhoto,
        width: 600,
        format: 'webp',
      })
    ).src,
    fullSrc: (
      await getImage({
        src: gamfestPerformancePhoto,
        width: 1400,
        format: 'webp',
      })
    ).src,
    alt: 'A street-level band performance at GAM[fest], with saxophonists and other musicians playing while festival tents line the road behind them.',
    caption: 'Street-level music between big-screen moments.',
    thumbPosition: 'center',
  },
];
---

<Section id="gallery" eyebrow="Level 03 // Gallery" title="From the big screen">
  <Reveal client:visible>
    <p class="lede">
      A few shots from the day — click any photo to view full size. More on the
      GAM[fest] Facebook page.
    </p>
  </Reveal>
  <Reveal client:visible delay={0.12}>
    <GalleryModal client:load items={galleryItems} />
  </Reveal>
</Section>
