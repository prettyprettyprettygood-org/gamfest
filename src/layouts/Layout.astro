---
import { getImage } from 'astro:assets';
import '@fontsource/vt323/400.css';
import '@fontsource/atkinson-hyperlegible/400.css';
import '@fontsource/atkinson-hyperlegible/700.css';
import '@fontsource/press-start-2p/400.css';
import '../styles/global.css';
import LevelSelectNav from '../components/motion/LevelSelectNav';
import ogImageSource from '../assets/images/gamfest-billboard.jpg';

export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

/** "Level select" nav — short labels, anchored to page sections (PRD §6) */
const levels = [
  { href: '#recap', label: 'Recap' },
  { href: '#lineup', label: 'Lineup' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#details', label: 'Info' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact' },
];

// Social share preview — the GAM[fest] billboard, cropped to the standard
// 1200x630 OG/Twitter card ratio and framed on the wordmark up top.
const ogImage = await getImage({
  src: ogImageSource,
  width: 1200,
  height: 630,
  fit: 'cover',
  position: 'top',
  format: 'jpg',
});
const ogImageUrl = new URL(ogImage.src, Astro.site);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0d0e10" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GAM[fest]" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="The GAM[fest] billboard: a five-story LED display showing the GAM[fest] logo above The Legend of Zelda title screen, against a clear blue sky."
    />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <!-- Sets data-hero-time before first paint so day/night CSS vars apply without flash -->
    <script is:inline>
      (function () {
        const override = new URLSearchParams(window.location.search).get(
          'heroTime',
        );
        if (override === 'day' || override === 'night') {
          document.documentElement.dataset.heroTime = override;
          return;
        }
        const h =
          +new Date().toLocaleString('en-US', {
            timeZone: 'America/New_York',
            hour: '2-digit',
            hour12: false,
          }) % 24;
        document.documentElement.dataset.heroTime =
          h >= 6 && h < 20 ? 'day' : 'night';
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__brand" href="#main">
          GAM<span class="site-header__brand-accent">[fest]</span>
        </a>
        <nav class="level-select" aria-label="Section">
          <LevelSelectNav levels={levels} client:visible />
        </nav>
      </div>
    </header>
    <slot />
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background-color: var(--color-bg-overlay);
    border-bottom: var(--border-width) solid var(--color-border);
    backdrop-filter: blur(0.5rem);
    -webkit-backdrop-filter: blur(0.5rem);
  }

  .site-header__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2) var(--space-5);
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-block: var(--space-2);
    padding-inline: var(--content-padding-inline);
  }

  .site-header__brand {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-decoration: none;
    color: var(--color-fg);
  }

  .site-header__brand:hover {
    color: var(--color-fg);
  }

  .site-header__brand-accent {
    color: var(--color-bg);
    background-color: var(--color-green);
    padding-inline: 0.15em;
  }

  /* :global — this list (and the toggle button below) is rendered by the
     LevelSelectNav React island, so Astro's scoped-style attribute never
     lands on it */
  :global(.level-select__list) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
  }

  /* Hamburger toggle — hidden on desktop; shown below 48rem once hydrated
     (a `hidden` button with no JS to open it would be worse than no button) */
  :global(.level-select__toggle) {
    display: none;
    align-items: center;
    justify-content: center;
    inline-size: 2.75rem;
    block-size: 2.75rem;
    padding: 0;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: transparent;
    color: var(--color-fg);
    cursor: pointer;
    transition:
      color 0.15s ease-out,
      border-color 0.15s ease-out;
  }

  :global(.level-select__toggle:hover) {
    color: var(--color-green);
    border-color: var(--color-green);
  }

  :global(.level-select__toggle-bars) {
    position: relative;
    inline-size: 1.25rem;
    block-size: 1px;
  }

  :global(.level-select__toggle-bars span) {
    position: absolute;
    inset-inline: 0;
    block-size: var(--border-width);
    background-color: currentColor;
    border-radius: var(--radius-sm);
    transition:
      transform 0.2s ease-out,
      opacity 0.15s ease-out;
  }

  :global(.level-select__toggle-bars span:nth-child(1)) {
    transform: translateY(-0.375rem);
  }

  :global(.level-select__toggle-bars span:nth-child(3)) {
    transform: translateY(0.375rem);
  }

  :global(
    .level-select__toggle[aria-expanded='true']
      .level-select__toggle-bars
      span:nth-child(1)
  ) {
    transform: translateY(0) rotate(45deg);
  }

  :global(
    .level-select__toggle[aria-expanded='true']
      .level-select__toggle-bars
      span:nth-child(2)
  ) {
    opacity: 0;
  }

  :global(
    .level-select__toggle[aria-expanded='true']
      .level-select__toggle-bars
      span:nth-child(3)
  ) {
    transform: translateY(0) rotate(-45deg);
  }

  /* Below 48rem the link list collapses into a dropdown anchored under the
     sticky header, opened via the hamburger toggle. `[data-open]` is only
     set once the island hydrates — until then the list keeps its default
     wrapped layout above, which also covers no-JS clients. */
  @media (max-width: 47.99rem) {
    :global(.level-select__toggle:not([hidden])) {
      display: inline-flex;
    }

    :global(.level-select__list[data-open]) {
      display: none;
      position: absolute;
      inset-inline: 0;
      top: 100%;
      flex-direction: column;
      gap: 0;
      margin: 0;
      padding: var(--space-2) var(--content-padding-inline) var(--space-4);
      background-color: rgb(5 6 7 / 80%);
      border-bottom: var(--border-width) solid var(--color-border);
      backdrop-filter: blur(0.5rem);
      -webkit-backdrop-filter: blur(0.5rem);
    }

    :global(.level-select__list[data-open='true']) {
      display: flex;
    }

    :global(.level-select__list[data-open] .nav-link) {
      width: 100%;
    }
  }
</style>
