---
import '@fontsource/vt323/400.css';
import '@fontsource/atkinson-hyperlegible/400.css';
import '@fontsource/atkinson-hyperlegible/700.css';
import '@fontsource/press-start-2p/400.css';
import '../styles/global.css';
import LevelSelectNav from '../components/motion/LevelSelectNav';

export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

/** "Level select" nav — short labels, anchored to page sections (PRD §6) */
const levels = [
  { href: '#recap', label: 'Recap' },
  { href: '#lineup', label: 'Lineup' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#details', label: 'Info' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Sets data-hero-time before first paint so day/night CSS vars apply without flash -->
    <script is:inline>
      (function () {
        const override = new URLSearchParams(window.location.search).get(
          'heroTime',
        );
        if (override === 'day' || override === 'night') {
          document.documentElement.dataset.heroTime = override;
          return;
        }
        const h =
          +new Date().toLocaleString('en-US', {
            timeZone: 'America/New_York',
            hour: '2-digit',
            hour12: false,
          }) % 24;
        document.documentElement.dataset.heroTime =
          h >= 6 && h < 20 ? 'day' : 'night';
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__brand" href="#main">
          GAM<span class="site-header__brand-accent">[fest]</span>
        </a>
        <nav class="level-select" aria-label="Section">
          <LevelSelectNav levels={levels} client:visible />
        </nav>
      </div>
    </header>
    <slot />
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background-color: var(--color-bg-overlay);
    border-bottom: var(--border-width) solid var(--color-border);
    backdrop-filter: blur(0.5rem);
    -webkit-backdrop-filter: blur(0.5rem);
  }

  .site-header__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2) var(--space-5);
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-block: var(--space-2);
    padding-inline: var(--content-padding-inline);
  }

  .site-header__brand {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-decoration: none;
    color: var(--color-fg);
  }

  .site-header__brand:hover {
    color: var(--color-fg);
  }

  .site-header__brand-accent {
    color: var(--color-bg);
    background-color: var(--color-green);
    padding-inline: 0.15em;
  }

  /* :global — this list is rendered by the LevelSelectNav React island, so
     Astro's scoped-style attribute never lands on it */
  :global(.level-select__list) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
  }
</style>
