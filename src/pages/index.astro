---
import { Image, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';
import Reveal from '../components/motion/Reveal';
import HeroCanvas from '../components/motion/HeroCanvas';
import GalleryModal from '../components/islands/GalleryModal';
import DialUpFaq from '../components/islands/DialUpFaq';
import LevelUpFaq from '../components/islands/LevelUpFaq';
import VideoPlayer from '../components/islands/VideoPlayer';
import dialUpSrc from '../assets/audio/dial-up_soundmp3.flac?url';
import coinSrc from '../assets/audio/pickupCoin.wav?url';
import billboardPhoto from '../assets/images/gamfest-billboard.jpg';
import bigScreenPhoto from '../assets/images/game-on-big-screen.webp';
import yoshiBillboardPhoto from '../assets/images/yoshi-billboard.webp';
import djBoardVideo from '../assets/video/dj-board.mp4';
import quickSavePhoto from '../assets/images/quicksave.png';
import quickSaveBandPhoto from '../assets/images/quicksave-band.png';
import marsMagmaPhoto from '../assets/images/mars-magma.png';
import dkAdventuresPhoto from '../assets/images/dk-adventures.jpg';
import christianDaltonPhoto from '../assets/images/christian-dalton-dj.png';
import christianDaltonPhoto2 from '../assets/images/christian-dalton-dj-1.png';
import gamFestSignPhoto from '../assets/images/gam-fest-sign.jpg';
import marsLivePhoto from '../assets/images/mars-live.jpg';
import marsRunPhoto from '../assets/images/mars-run.jpg';
import brosPhoto from '../assets/images/bros.png';
import spongebobPhoto from '../assets/images/spongebob.png';
import thisBigCatPhoto from '../assets/images/this-big-cat.png';
import jamPhoto from '../assets/images/jam.png';
import vestPhoto from '../assets/images/vest.png';
import ffvPhoto from '../assets/images/final-fantasy-v.png';
import silentHillFPhoto from '../assets/images/silent-hill-f.png';
import isThisRealPhoto from '../assets/images/is-this-real.png';

const discordUrl = 'https://discord.gg/KJw4trPeg';
const facebookUrl = 'https://fb.me/1TyB3AQ3p7hPRuE';
const contactEmail = 'dom@cerquetti.solutions';
const formspreeUrl = 'https://formspree.io/f/xvznalwp';
const charlesStreetPromenadeUrl = 'https://charlesstreetpromenade.com/';
const mapEmbedUrl =
  'https://www.google.com/maps?q=E.+Lanvale+St+%26+N.+Charles+St,+Baltimore,+MD&output=embed';
const mapUrl =
  'https://www.google.com/maps/search/?api=1&query=E.+Lanvale+St+%26+N.+Charles+St,+Baltimore,+MD';

/** The day's three headlining acts — given the bigger "act card" treatment */
const featuredActs = [
  {
    name: 'Quick Save!',
    role: 'live in front of the billboard',
    image: {
      src: quickSavePhoto,
      alt: 'Stylized cartoon-avatar lineup graphic for Quick Save, showing the six band members as character portraits against a dark background.',
    },
    secondaryImage: {
      src: quickSaveBandPhoto,
      alt: 'Quick Save performing live outdoors, members playing guitar and singing on a stage against a city skyline backdrop.',
    },
    bio: 'Taking a break from the studio to play their first summer show, Quick Save brought their jazz/rock/meme fusion to the GAM[fest] stage. They played favorites and new tunes from their upcoming studio debut.',
    socials: [
      {
        name: 'instagram' as const,
        href: 'https://www.instagram.com/quicksavebaltimore/',
        label: 'Quick Save on Instagram',
      },
      {
        name: 'facebook' as const,
        href: 'http://facebook.com/quicksaveband/',
        label: 'Quick Save on Facebook',
      },
      {
        name: 'youtube' as const,
        href: 'https://www.youtube.com/QuickSaveBand',
        label: 'Quick Save on YouTube',
      },
      {
        name: 'bandcamp' as const,
        href: 'https://quicksave.bandcamp.com/',
        label: 'Quick Save on Bandcamp',
      },
    ],
  },
  {
    name: 'DJ Christian Dalton',
    role: 'Linking the sets together',
    image: {
      src: christianDaltonPhoto,
      alt: 'Christian Dalton DJing at a table with a laptop in front of a screen showing retro game graphics.',
    },
    secondaryImage: {
      src: christianDaltonPhoto2,
      alt: 'Christian Dalton at the DJ booth from a wider angle, with a lit-up stage setup behind him.',
    },
    bio: "A Maryland-native DJ/producer bringing dance music and excellent vibes — a particular fan of funky basslines, driving grooves, and entrancing leads. His goal is simple: take you on a journey you didn't know you needed to hear.",
    socials: [
      {
        name: 'instagram' as const,
        href: 'https://www.instagram.com/christiandalton.music/',
        label: 'Christian Dalton on Instagram',
      },
      {
        name: 'link' as const,
        href: 'https://linktr.ee/Christian.Dalton',
        label: 'Christian Dalton on Linktree',
      },
    ],
  },
  {
    name: 'Mars Magma × DK Adventures',
    role: 'Live Zelda speedrun',
    image: {
      src: marsMagmaPhoto,
      alt: 'Mars Magma performing live in a bright orange wig and headlamp behind a bank of game consoles and a monitor, with the "Hipscore: The Happy Hour for Gamers" logo overlaid.',
    },
    secondaryImage: {
      src: dkAdventuresPhoto,
      alt: 'Dom and Kevin of DK Adventures performing on an outdoor wooden stage surrounded by trees — one on drums, one on keyboard and vocals — with a "DK Adventures" text overlay.',
    },
    bio: 'A full Legend of Zelda speedrun on the billboard, scored in real time: Mars Magma ran the game while Dom and Kevin of DK Adventures improvised a live soundtrack to every room and rupee.',
    socials: [
      {
        name: 'instagram' as const,
        href: 'https://www.instagram.com/marsapalooza_arcade/',
        label: 'Mars Magma on Instagram',
      },
      {
        name: 'facebook' as const,
        href: 'https://www.facebook.com/DKAdventuresBand/',
        label: 'DK Adventures on Facebook',
      },
    ],
  },
];

/** The rest of the day's "also unlocked" activities — a lighter-weight list,
 * not cards, so four items don't leave an awkward lone card in a 3-up grid */
const lineupExtras = [
  {
    title: 'Freeplay, unlocked',
    body: 'Anyone could grab a controller — on the consoles set up streetside, or on the billboard itself.',
  },
  {
    title: 'Tabletop crews ran live demos',
    body: 'Card and tabletop folks set up shop and showed off their games to passersby all afternoon.',
  },
  {
    title: 'Live art, drawn right on the board',
    body: 'Local artists turned the five-story screen into a canvas between sets.',
  },
  {
    title: 'Nerd trivia, every hour on the hour',
    body: 'A fresh round (and a fresh stack of prizes) every hour, all day long.',
  },
];

const galleryItems = [
  {
    thumbSrc: (
      await getImage({ src: billboardPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: billboardPhoto, width: 1400 })).src,
    alt: 'A five-story LED billboard displaying the Legend of Zelda 1986 title screen — sword, shield emblem, and "Push Start Button" — with the GAM[fest] "Games | Art | Music | Fest" banner and the date and web address overlaid above and below, against a clear blue sky.',
    caption: 'The billboard: The Legend of Zelda, five stories tall.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({ src: bigScreenPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: bigScreenPhoto, width: 1200 })).src,
    alt: 'A crowd gathers on a Baltimore street corner, watching Super Mario Bros. run on a giant LED billboard mounted above a brick warehouse, with traffic cones and an inflatable arch set up for the festival on the street below.',
    caption: 'The crowd gathers as Mario takes the big screen.',
    thumbPosition: 'top',
  },
  {
    thumbSrc: (
      await getImage({ src: yoshiBillboardPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: yoshiBillboardPhoto, width: 1200 })).src,
    alt: "A tall view of the LED billboard mounted above a Station North brick warehouse, displaying the overworld map from Super Mario World's Yoshi's Island, with festival tents and a small crowd gathered on the street below.",
    caption:
      "Yoshi's Island, five stories up — and a street-level view of the whole setup.",
    thumbPosition: 'top center',
  },
  {
    thumbSrc: (
      await getImage({ src: gamFestSignPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: gamFestSignPhoto, width: 1400 })).src,
    alt: 'A GAM[fest] festival sign on display at the event.',
    caption: 'The GAM[fest] sign welcoming attendees.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({ src: marsLivePhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: marsLivePhoto, width: 1400 })).src,
    alt: 'Mars performing live on stage at GAM[fest].',
    caption: 'Mars live on stage.',
    thumbPosition: 'center',
  },
  {
    thumbSrc: (
      await getImage({ src: marsRunPhoto, width: 600, format: 'webp' })
    ).src,
    fullSrc: (await getImage({ src: marsRunPhoto, width: 1400 })).src,
    alt: 'Mars running during a performance at GAM[fest].',
    caption: 'Mars bringing the energy.',
    thumbPosition: 'center',
  },
];

const details = [
  {
    term: 'When',
    description:
      'Saturday, June 6, 2026 — 11am to 6pm (the weather cooperated)',
  },
  {
    term: 'Where',
    description:
      'Station North, Baltimore, MD — outdoors at E. Lanvale St & N. Charles St, near Metro Gallery',
    link: { href: mapUrl, label: 'Open in Google Maps' },
  },
  {
    term: 'Who',
    description: "Baltimore's Charles Street Promenade festival",
    link: {
      href: charlesStreetPromenadeUrl,
      label: 'charlesstreetpromenade.com',
    },
  },
];

const faqs = [
  {
    id: 'real',
    question: 'Is this a real event?',
    answer:
      'Yes — GAM[fest] #1 really happened, in real life. It was not an AI hallucination. We promise.',
  },
  {
    id: 'pronunciation',
    question: 'How is GAM[fest] pronounced?',
    answer: 'Like "JAM" + "fest" (the G is silent, like in "GIF"). Probably.',
  },
  {
    id: 'next',
    question: "When's the next one?",
    answer:
      "TBD — we're hoping to make this an annual thing. (Technically GAM[fest] #1 wasn't the first GAMfest either: J.C.H. ran a few of these back in the day. History write-up coming soon.) Follow on Discord or Facebook and you'll hear it the second we know.",
  },
  {
    id: 'size',
    question: 'How big was this going to be?',
    answer:
      'Turned out about as expected: a pretty chill crowd wandering through from the larger festival, plenty of chances for people to get a turn on the big screen. An unholy combo of "low-key" and "giant billboard" — and it ruled.',
  },
  {
    id: 'afterparty',
    question: "Where's the after-party?",
    answer:
      "All the cool kids know you sprint a few blocks downtown for the 8pm showing of Baltimore Rock Opera Society's newest rock opera: American Vamp.",
  },
  {
    id: 'slang',
    question:
      'Why doesn\'t your promo material sling any catchy millennial gamer slang like "LEVEL UP" and "GET AN EXTRA LIFE"?',
    answer:
      '"Some idiot left Dom in charge of making the website." — Alas, I have arrived. As you can see, I have sprinkled some millennial gamer slang in. ',
  },
  {
    id: 'dialup',
    question: 'I have to go / my mom has to use the phone now.',
    answer: 'OK, bye.',
  },
];
---

<Layout
  title="GAM[fest] — Games | Art | Music | Fest"
  description="GAM[fest] is a Baltimore festival celebrating games, art, and music — recapping GAM[fest] #1 (a giant LED billboard running classic videogames) and pointing the way to the next one, TBD."
>
  <main id="main">
    <div class="page-glow" aria-hidden="true"></div>
    <header class="hero">
      <div class="hero__canvas-wrap" aria-hidden="true">
        <HeroCanvas client:load />
      </div>
      <div class="hero__content">
        <p class="hero__tagline">Games | Art | Music | Fest</p>
        <h1 class="hero__wordmark">
          GAM<span class="hero__wordmark-accent">[fest]</span>
        </h1>
        <p class="hero__pitch">That happened. It ruled.</p>
        <div class="hero__badges">
          <Badge variant="green">Free</Badge>
          <Badge variant="amber">IRL</Badge>
          <Badge variant="magenta">TBD 2027</Badge>
        </div>
        <div class="hero__actions">
          <Button href={discordUrl} variant="primary">Follow on Discord</Button>
          <Button href={facebookUrl} variant="secondary"
            >Follow on Facebook</Button
          >
        </div>
      </div>
    </header>

    <Section id="recap" eyebrow="Level 01 // Recap" title="How it went">
      <Reveal client:visible>
        <p class="lede">
          Somebody gave the nerds a video cable hooked up to a giant LED
          billboard. This was going to get nuts — and it did, in the best way.
        </p>
        <p>
          GAM[fest] #1 took over a corner of Baltimore's Charles Street
          Promenade with free-play on a five-story screen, live music following
          along to a Zelda 1 speedrun, tabletop demos, live art on the board,
          and an hourly stream of nerd trivia. Folks wandered in from the bigger
          festival next door, grabbed a controller, and got a turn on the
          biggest screen they'll probably ever play on. <a href="#gallery"
            >See the gallery</a
          > for the highlights, or <a href="#lineup">check the lineup</a> for who
          made it happen.
        </p>
      </Reveal>
    </Section>

    <Section
      id="lineup"
      eyebrow="Level 02 // Lineup"
      title="Achievements unlocked"
    >
      <Reveal client:visible>
        <p class="lede">
          A run-down of who and what made the day — headliners first, then
          everything else that was happening on (and around) the big screen.
        </p>
      </Reveal>
      <Reveal client:visible delay={0.12}>
        <ul class="acts">
          {
            featuredActs.map((act) => (
              <li>
                <Card headingLevel="h3">
                  <div class="act-card__media">
                    {act.image && (
                      <Image
                        src={act.image.src}
                        alt={act.image.alt}
                        class="act-card__image"
                        width={480}
                      />
                    )}
                    {'secondaryImage' in act && act.secondaryImage && (
                      <Image
                        src={act.secondaryImage.src}
                        alt={act.secondaryImage.alt}
                        class="act-card__image act-card__image--secondary"
                        width={320}
                      />
                    )}
                    {!act.image && (
                      <p class="act-card__eyebrow" aria-hidden="true">
                        Achievement unlocked
                      </p>
                    )}
                  </div>
                  <div class="act-card__body">
                    <p class="act-card__role">{act.role}</p>
                    <h3 class="act-card__name">{act.name}</h3>
                    <p class="act-card__bio">{act.bio}</p>
                    <ul class="act-card__socials">
                      {act.socials.map((social) => (
                        <li>
                          <a
                            class="icon-link"
                            href={social.href}
                            target="_blank"
                            rel="noreferrer"
                          >
                            <Icon name={social.name} label={social.label} />
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </Card>
              </li>
            ))
          }
        </ul>
      </Reveal>
      <div class="lineup-extras-wrap">
        <div class="lineup-extras-col">
          <Reveal client:visible delay={0.18}>
            <h3 class="lineup-extras__heading">Also unlocked that day</h3>
          </Reveal>
          <ul class="lineup-extras" data-stagger>
            {
              lineupExtras.map((entry, index) => (
                <li class="lineup-extras__item" style={`--stagger-i: ${index}`}>
                  <span class="lineup-extras__index" aria-hidden="true">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div>
                    <h4 class="lineup-extras__title">{entry.title}</h4>
                    <p>{entry.body}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>
        <Reveal client:visible delay={0.28} className="lineup-extras-video-col">
          <VideoPlayer client:visible src={djBoardVideo} />
        </Reveal>
      </div>
    </Section>

    <Section
      id="gallery"
      eyebrow="Level 03 // Gallery"
      title="From the big screen"
    >
      <Reveal client:visible>
        <p class="lede">
          A few shots from the day — click any photo to view full size. More on
          the GAM[fest] Facebook page.
        </p>
      </Reveal>
      <Reveal client:visible delay={0.12}>
        <GalleryModal client:visible items={galleryItems} />
      </Reveal>
    </Section>

    <Section id="details" eyebrow="Level 04 // Info">
      <Reveal client:visible>
        <div class="details-layout">
          <div class="details-layout__left">
            <h2 class="details-layout__title">The details (for next time)</h2>
            <p class="lede">
              Here's how GAM[fest] #1 went down — good context for whenever #2
              lands.
            </p>
            <dl class="details-list">
              {
                details.map((row) => (
                  <div class="details-list__row">
                    <dt class="details-list__term">{row.term}</dt>
                    <dd class="details-list__description">
                      {row.description}
                      {row.link && (
                        <>
                          {' — '}
                          <a
                            href={row.link.href}
                            target="_blank"
                            rel="noreferrer"
                          >
                            {row.link.label}
                          </a>
                        </>
                      )}
                    </dd>
                  </div>
                ))
              }
            </dl>
          </div>
          <div class="details-map-wrap">
            <div class="free-burst" aria-label="Free event">
              <span>FREE</span>
              <span class="free-burst__bang">!</span>
            </div>
            <figure class="details-map">
              <iframe
                class="details-map__frame"
                src={mapEmbedUrl}
                title="Map of E. Lanvale St & N. Charles St, Station North, Baltimore, MD"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
              <figcaption class="details-map__caption">
                <Icon name="map-pin" />
                <a href={mapUrl} target="_blank" rel="noreferrer"
                  >Open in Google Maps</a
                >
              </figcaption>
            </figure>
          </div>
        </div>
      </Reveal>
    </Section>

    <Section
      id="faq"
      eyebrow="Level 05 // FAQ"
      title="“Frequently” asked questions"
    >
      <Reveal client:visible>
        <div class="faq-list">
          {
            faqs.map((faq) => {
              if (faq.id === 'dialup') {
                return (
                  <DialUpFaq
                    client:visible
                    question={faq.question}
                    answer={faq.answer}
                    audioSrc={dialUpSrc}
                  />
                );
              }
              if (faq.id === 'slang') {
                return (
                  <LevelUpFaq
                    client:visible
                    question={faq.question}
                    answer={faq.answer}
                    coinSrc={coinSrc}
                  />
                );
              }
              if (faq.id === 'real') {
                return (
                  <details class="faq-item">
                    <summary class="faq-item__question">{faq.question}</summary>
                    <div class="faq-item__body--images">
                      <div class="faq-item__answer">
                        <p>Yes — GAM[fest] #1 really happened, in real life.</p>
                        <p>It was not an AI hallucination.</p>
                        <p>We promise.</p>
                      </div>
                      <div class="faq-item__images">
                        <Image
                          src={isThisRealPhoto}
                          alt="Proof that GAM[fest] #1 was a real event"
                          width={280}
                          class="faq-item__single-img"
                        />
                      </div>
                    </div>
                  </details>
                );
              }
              if (faq.id === 'pronunciation') {
                return (
                  <details class="faq-item">
                    <summary class="faq-item__question">{faq.question}</summary>
                    <div class="faq-item__body--images">
                      <p class="faq-item__answer">{faq.answer}</p>
                      <div
                        class="faq-rebus"
                        role="img"
                        aria-label="Rebus: JAM plus VEST minus V (Final Fantasy V) plus F (Silent Hill F) equals GAM[fest]"
                      >
                        <figure class="faq-rebus__step">
                          <Image src={jamPhoto} alt="" width={72} />
                        </figure>
                        <span class="faq-rebus__op" aria-hidden="true">+</span>
                        <figure class="faq-rebus__step">
                          <Image
                            src={vestPhoto}
                            alt=""
                            width={72}
                          />
                        </figure>
                        <span class="faq-rebus__op" aria-hidden="true">-</span>
                        <figure class="faq-rebus__step">
                          <Image src={ffvPhoto} alt="" width={72} />
                        </figure>
                        <span class="faq-rebus__op" aria-hidden="true">+</span>
                        <figure class="faq-rebus__step">
                          <Image
                            src={silentHillFPhoto}
                            alt=""
                            width={72}
                          />
                        </figure>
                      </div>
                    </div>
                  </details>
                );
              }
              if (faq.id === 'afterparty') {
                return (
                  <details class="faq-item">
                    <summary class="faq-item__question">{faq.question}</summary>
                    <div class="faq-item__body--images">
                      <p class="faq-item__answer">
                        All the cool kids know you sprint a few blocks downtown
                        for the 8pm showing of{' '}
                        <a
                          href="https://www.baltimorerockopera.org/"
                          target="_blank"
                          rel="noreferrer"
                        >
                          Baltimore Rock Opera Society
                        </a>
                        's newest rock opera: American Vamp.
                      </p>
                      <div class="faq-item__images">
                        <Image
                          src={brosPhoto}
                          alt="Bros at the after-party"
                          width={340}
                          class="faq-item__single-img"
                        />
                      </div>
                    </div>
                  </details>
                );
              }
              if (faq.id === 'size') {
                return (
                  <details class="faq-item">
                    <summary class="faq-item__question">{faq.question}</summary>
                    <div class="faq-item__body--images">
                      <p class="faq-item__answer">{faq.answer}</p>
                      <div class="faq-item__images">
                        <Image
                          src={thisBigCatPhoto}
                          alt="This big (cat demonstrating size)"
                          width={220}
                          class="faq-item__single-img"
                        />
                      </div>
                    </div>
                  </details>
                );
              }
              if (faq.id === 'next') {
                return (
                  <details class="faq-item">
                    <summary class="faq-item__question">{faq.question}</summary>
                    <div class="faq-item__body--images">
                      <p class="faq-item__answer">{faq.answer}</p>
                      <div class="faq-item__images">
                        <Image
                          src={spongebobPhoto}
                          alt="Spongebob squarepants holding a TBD sign"
                          width={220}
                          class="faq-item__single-img"
                        />
                      </div>
                    </div>
                  </details>
                );
              }
              return (
                <details class="faq-item">
                  <summary class="faq-item__question">{faq.question}</summary>
                  <p class="faq-item__answer">{faq.answer}</p>
                </details>
              );
            })
          }
        </div>
      </Reveal>
    </Section>

    <Section
      id="contact"
      eyebrow="Continue?"
      title="Follow for the announcement"
    >
      <Reveal client:visible>
        <p class="lede">
          GAM[fest] #2 is TBD — but we'll shout about it the moment it's locked
          in. Insert coin (or just hit follow) so you hear it first:
        </p>
      </Reveal>
      <Reveal client:visible delay={0.12}>
        <div class="follow-card">
          <a
            class="follow-item"
            href={discordUrl}
            target="_blank"
            rel="noreferrer"
          >
            <Icon name="discord" label="Discord" />
            <div class="follow-item__text">
              <p class="follow-item__label">Discord</p>
              <p class="follow-item__sub">Join the server</p>
            </div>
          </a>
          <a
            class="follow-item"
            href={facebookUrl}
            target="_blank"
            rel="noreferrer"
          >
            <Icon name="facebook" label="Facebook" />
            <div class="follow-item__text">
              <p class="follow-item__label">Facebook</p>
