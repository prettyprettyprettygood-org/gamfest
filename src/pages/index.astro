<script>
  // Stagger the "Also unlocked" list items into view
  const staggerLists = document.querySelectorAll<HTMLElement>('[data-stagger]');
  if (staggerLists.length) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('lineup-extras--visible');
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    staggerLists.forEach((el) => obs.observe(el));
  }

  // Cursor-following spotlight — single fixed overlay across the whole page
  document.addEventListener('mousemove', (e) => {
    document.documentElement.style.setProperty('--cursor-x', `${e.clientX}px`);
    document.documentElement.style.setProperty('--cursor-y', `${e.clientY}px`);
  });

  // Sync video column height to the left column so they're the same
  const leftCol = document.querySelector<HTMLElement>('.lineup-extras-col');
  const videoCol = document.querySelector<HTMLElement>(
    '.lineup-extras-video-col',
  );
  if (leftCol && videoCol) {
    const wide = window.matchMedia('(min-width: 48rem)');
    const sync = () => {
      if (wide.matches) {
        videoCol.style.height = `${leftCol.offsetHeight}px`;
      } else {
        videoCol.style.height = '';
      }
    };
    sync();
    new ResizeObserver(sync).observe(leftCol);
    wide.addEventListener('change', sync);
  }
</script>

