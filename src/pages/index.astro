---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../sections/HeroSection.astro';
import RecapSection from '../sections/RecapSection.astro';
import LineupSection from '../sections/LineupSection.astro';
import GallerySection from '../sections/GallerySection.astro';
import DetailsSection from '../sections/DetailsSection.astro';
import FaqSection from '../sections/FaqSection.astro';
import ContactSection from '../sections/ContactSection.astro';
import SiteFooter from '../sections/SiteFooter.astro';
---

<Layout
  title="GAM[fest] — Games | Art | Music | Fest"
  description="GAM[fest] is a Baltimore festival celebrating games, art, and music — recapping GAM[fest] #1 (a giant LED billboard running classic videogames) and pointing the way to the next one, TBD."
>
  <main id="main">
    <div class="page-glow" aria-hidden="true"></div>
    <HeroSection />
    <RecapSection />
    <LineupSection />
    <GallerySection />
    <DetailsSection />
    <FaqSection />
    <ContactSection />
  </main>
  <SiteFooter />
</Layout>

<script>
  document.addEventListener('mousemove', (e) => {
    document.documentElement.style.setProperty('--cursor-x', `${e.clientX}px`);
    document.documentElement.style.setProperty('--cursor-y', `${e.clientY}px`);
  });
</script>

<style>
  .page-glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      700px circle at var(--cursor-x, 50vw) var(--cursor-y, 50vh),
      rgb(var(--color-green-rgb) / 0.05),
      transparent 55%
    );
  }
</style>
